{
  "name": "jlpt-simulator",
  "private": true,
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "ts-node -P tsconfig.seed.json supabase/seed/seed.ts",
    "db:types": "supabase gen types typescript --project-id cmlxfddegfzwisuaiokh > supabase/types.ts",
    "db:verify": "ts-node -P tsconfig.seed.json tools/verify-seed.ts",
    "db:update-audio": "ts-node -P tsconfig.seed.json tools/update-audio-urls.ts",
    "convert": "ts-node tools/converter/src/index.ts"
  },
  "devDependencies": {
    "dotenv": "^17.4.1",
    "ts-node": "^10.9.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "npm@10.0.0"
}

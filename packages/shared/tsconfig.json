{
  "compilerOptions": {
    "target":           "ES2020",
    "lib":              ["ES2020"],
    "module":           "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck":     true,
    "strict":           true,
    "noUnusedLocals":   true,
    "noUnusedParameters": true,
    "noEmit":           true,
    "isolatedModules":  true
  },
  "include": ["src"]
}
